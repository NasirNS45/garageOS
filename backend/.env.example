# Copy to .env and fill in values
DATABASE_URL=postgresql+asyncpg://garage_os:garage_os@localhost:5432/garage_os_db
SECRET_KEY=change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# WhatsApp (Twilio sandbox — leave blank to disable in v1)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# App
ENVIRONMENT=development
LOG_LEVEL=INFO

# Backend self-reference (health/internal). Not used for customer links.
APP_BASE_URL=http://localhost:8000

# Public frontend base URL — used to build customer-facing invoice and tracking
# links (the invoice/track pages are React routes on the frontend).
# In production, set this to your Vercel/custom domain, e.g. https://garage-os.vercel.app
WEB_BASE_URL=http://localhost:5173

# CORS — comma-separated list of allowed origins.
# In production, set to your frontend domain: https://myworkshop.com
# Leave as * only for local development.
CORS_ORIGINS=*

# Background scheduler (service reminders + owner daily digest).
# Disable on multi-worker hosts to avoid duplicate sends, or run a single worker.
SCHEDULER_ENABLED=true
REMINDER_SEND_HOUR=9    # 24h local hour to dispatch due service reminders
DIGEST_SEND_HOUR=20     # 24h local hour to send the owner daily digest

# Photo storage (S3-compatible, e.g. Cloudflare R2). Leave blank to disable photos.
# Create an R2 bucket, an API token (Object Read & Write), and a public bucket URL.
STORAGE_ENDPOINT_URL=     # e.g. https://<account_id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_PUBLIC_URL=       # public base URL for objects, e.g. https://pub-xxxx.r2.dev
STORAGE_REGION=auto
