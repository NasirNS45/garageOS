# Copy to .env and fill in values
DATABASE_URL=postgresql+asyncpg://garage_os:garage_os@localhost:5432/garage_os_db
SECRET_KEY=change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# WhatsApp (Twilio sandbox — leave blank to disable in v1)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# App
ENVIRONMENT=development
LOG_LEVEL=INFO

# Public-facing base URL — used in invoice links sent to customers via WhatsApp.
# In production, set this to your actual domain: https://myworkshop.com
APP_BASE_URL=http://localhost:8000

# CORS — comma-separated list of allowed origins.
# In production, set to your frontend domain: https://myworkshop.com
# Leave as * only for local development.
CORS_ORIGINS=*
