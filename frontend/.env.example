# Copy to .env for local development
# VITE_ prefix makes variables available in the browser bundle.

# Backend host for the Vite dev-server proxy.
# In production, nginx handles the proxy — this variable is only used
# during local development (npm run dev).
VITE_API_HOST=http://localhost:8000

# Production API base URL — set when frontend and backend are deployed
# separately (e.g. Vercel frontend + Railway backend). Leave unset when
# the API is reverse-proxied under the same domain.
# VITE_API_URL=https://api.your-domain.com/api/v1
